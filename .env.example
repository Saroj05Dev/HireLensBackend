# Server Configuration
PORT=3500
NODE_ENV=development

# Database
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster0

# JWT Secrets (Generate strong random strings for production)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS and Socket.IO)
FRONTEND_URL=http://localhost:5173

# Email (Brevo)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxx
EMAIL_FROM=your-email@gmail.com
